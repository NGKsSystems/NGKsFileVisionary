        "src/ui/TreeSnapshotPreviewDialog.cpp",
        "src/ui/ArchiveExplorer.cpp",
        "src/core/FileScanner.cpp",
        "src/core/FileModel.cpp",
        "src/core/TreeSnapshotService.cpp",
        "src/core/ArchiveService.cpp",
        "src/core/ArchiveModel.cpp",
        "src/core/NavigationHistory.cpp",
        "src/core/db/SqlHelpers.cpp",
        "src/core/db/DbConnection.cpp",
        "src/core/db/DbMigrations.cpp",
        "src/core/db/MetaStore.cpp",
        "src/core/db/EntryRepository.cpp",
        "src/core/db/VolumeRepository.cpp",
        "src/core/db/FavoriteRepository.cpp",
        "src/util/PathUtils.cpp"
